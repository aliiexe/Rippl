# App URL (required for OAuth redirects; use your Vercel URL in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk (sign-up, sign-in, sessions) — https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase (database) — https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (Gmail + Calendar) — https://console.cloud.google.com
# Redirect URI must be: NEXT_PUBLIC_APP_URL/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# OpenRouter (AI email drafting) — https://openrouter.ai
OPENROUTER_API_KEY=
# Optional: OPENROUTER_DEFAULT_MODEL=openrouter/free

# Optional: Cron for scheduled emails (free tier). If set, only requests with this secret are accepted.
# Use with external cron (e.g. cron-job.org) or Vercel Pro cron. Leave empty to allow unauthenticated calls.
# CRON_SECRET=your-random-secret
